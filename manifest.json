{
  "manifest_version": 3,

  "name": "FocusFlow",

  "description": "Your All-in-One Productivity Browser Companion.",

  "version": "1.0.0",

  "action": {
    "default_popup": "popup.html",
    "default_title": "FocusFlow"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "notifications",
    "alarms"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "icons": {
    "16": "assets/logo/icon16.png",
    "48": "assets/logo/icon48.png",
    "128": "assets/logo/icon128.png"
  }
}